<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    
    <Properties>
        <Property name="LOG_DIR">logs</Property>
        <Property name="APP_NAME">hermes-sdk</Property>
    </Properties>

    <Appenders>
        
        <!-- 控制台 -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>
        
        <!-- 应用日志（按大小滚动） -->
        <RollingFile name="AppLog" fileName="${LOG_DIR}/${APP_NAME}.log"
                    filePattern="${LOG_DIR}/${APP_NAME}-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{60} - %msg%n"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="10" fileIndex="min"/>
        </RollingFile>
        
        <!-- 错误日志单独记录 -->
        <RollingFile name="ErrorLog" fileName="${LOG_DIR}/${APP_NAME}-error.log"
                     filePattern="${LOG_DIR}/${APP_NAME}-error-%d{yyyy-MM-dd}-%i.log.gz">
            <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{60} - %msg%n"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="5MB"/>
            </Policies>
            <DefaultRolloverStrategy max="5" fileIndex="min"/>
        </RollingFile>
        
    </Appenders>

    <Loggers>
        <!-- 业务日志 -->
        <Logger name="com.hermes.sdk" level="debug" additivity="false">
            <AppenderRef ref="AppLog"/>
            <AppenderRef ref="Console"/>
        </Logger>
        
        <!-- OkHttp 日志 -->
        <Logger name="okhttp3" level="warn" additivity="false">
            <AppenderRef ref="AppLog"/>
        </Logger>
        
        <!-- Jackson 日志 -->
        <Logger name="com.fasterxml.jackson" level="warn" additivity="false">
            <AppenderRef ref="AppLog"/>
        </Logger>
        
        <!-- Root Logger -->
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AppLog"/>
            <AppenderRef ref="ErrorLog"/>
        </Root>
    </Loggers>

</Configuration>